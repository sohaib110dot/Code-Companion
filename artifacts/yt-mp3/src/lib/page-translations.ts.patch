// Add this at the end of the file, before export function getPageTranslations

const pageTranslationCache: Record<string, Record<string, string>> = {};

async function translatePageText(text: string, targetLang: LangCode): Promise<string> {
  if (!text || targetLang === "en") return text;
  if (!pageTranslationCache[targetLang]) pageTranslationCache[targetLang] = {};
  if (pageTranslationCache[targetLang][text]) return pageTranslationCache[targetLang][text];

  const LANG_CODES: Record<LangCode, string> = {
    en: "en", es: "es", de: "de", ar: "ar", pt: "pt", ru: "ru",
    id: "id", tr: "tr", fr: "fr", it: "it", hi: "hi", ja: "ja", ko: "ko", th: "th",
  };

  try {
    const response = await fetch(
      `https://api.mymemory.translated.net/get?q=${encodeURIComponent(text)}&langpair=en|${LANG_CODES[targetLang]}`
    );
    if (response.ok) {
      const data = await response.json();
      const translated = data.responseData?.translatedText || text;
      pageTranslationCache[targetLang][text] = translated;
      return translated;
    }
  } catch (e) {
    // Silently fail
  }
  return text;
}

export function getPageTranslationsWithFallback(lang: LangCode): PageTranslations {
  const baseTranslations = pageTranslations[lang] || pageTranslations.en;
  
  // Return a Proxy that auto-translates missing keys
  return new Proxy(baseTranslations, {
    get(target: any, prop: string | symbol) {
      const value = target[prop];
      if (typeof value === "string" && lang !== "en") {
        // If value is missing (undefined) or is a key (no translation), queue translation
        if (!value || value === prop) {
          const enValue = pageTranslations.en[prop as TranslationKey];
          if (enValue && typeof enValue === "string") {
            // Start translation in background
            translatePageText(enValue, lang).catch(() => {});
            return enValue; // Return English while translating
          }
        }
      }
      return value;
    }
  });
}
